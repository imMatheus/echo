{
  "name": "echo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' --filter './apps/*' build",
    "dev": "bun run --filter @echo/server --filter @echo/web dev",
    "start": "bun apps/server/src/index.ts",
    "test": "bun run --filter './packages/*' --filter './apps/*' test",
    "typecheck": "bun run --filter './packages/*' --filter './apps/*' typecheck"
  }
}
