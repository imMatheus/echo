{
  "name": "echo",
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "build": "bun run --filter echo-context-mcp --filter @echo/web build",
    "dev": "bun run --parallel --filter @echo/server --filter @echo/web dev",
    "dev:server": "bun run --filter @echo/server dev",
    "dev:web": "bun run --filter @echo/web dev",
    "start": "cd apps/server && bun --env-file=.env src/index.ts",
    "test": "bun run --filter './packages/*' --filter './apps/*' test",
    "typecheck": "bun run --filter './packages/*' --filter './apps/*' typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
