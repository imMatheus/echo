# Copy to apps/server/.env. This file contains server-only settings.
# The separately deployed Vite app has its own apps/web/.env file.

# --- Database -----------------------------------------------------------
# Docker Compose reads this file when invoked with:
# docker compose --env-file apps/server/.env up -d --build
#
# Leave blank to use the local Postgres container. Echo uses
# postgres://echo:echo@localhost:5433/echo when run on the host; Compose uses
# its internal db service automatically. Set this one variable to any external
# PostgreSQL URL (including PlanetScale Postgres) to use it everywhere.
# Echo uses the URL exactly as provided for both application traffic and migrations.
#
# PlanetScale: paste the *direct* connection string (port 5432), not the pooled
# PgBouncer one (port 6432). Boot-time migrations hold a session advisory lock,
# which transaction pooling cannot support. Keep sslmode=require in the URL.
DATABASE_URL=
DEV_DB_PORT=5433

# --- Server -------------------------------------------------------------
# Public dashboard URL used in authentication emails (HTTPS also enables Secure cookies).
# Use http://localhost:5173 for Vite development or your public HTTPS web URL.
APP_URL=
# Set true to run behind a reverse proxy (respect X-Forwarded-* headers).
TRUST_PROXY=false
# Set true after provisioning accounts when running a private instance.
DISABLE_SIGNUP=false
SESSION_TTL_DAYS=30
# Docker Compose host interface. Keep loopback until trusted accounts are provisioned
# and public signup is disabled.
BIND_ADDRESS=127.0.0.1
PORT=8080
LOG_LEVEL=info
# The one browser origin allowed to make credentialed cross-origin API requests.
WEB_ORIGIN=http://localhost:5173
# Use `none` only when web and API are on different sites; it requires HTTPS APP_URL.
COOKIE_SAME_SITE=lax

# --- Transactional email and authentication links ----------------------
# console prints complete emails to server logs for local development.
# resend sends through the Resend HTTP API; adding another provider only
# requires a new adapter in apps/server/src/email/provider.ts.
EMAIL_PROVIDER=console
EMAIL_FROM=Echo <auth@example.com>
EMAIL_REPLY_TO=
RESEND_API_KEY=
# Required and unique with EMAIL_PROVIDER=resend. Generate with: openssl rand -base64 48
AUTH_TOKEN_SECRET=

# --- Semantic search ----------------------------------------------------
# pgvector stores the vectors; a provider must generate them.
# none   = keyword (full-text) search only, zero external dependencies
# openai = requires OPENAI_API_KEY   (default model text-embedding-3-small)
# voyage = requires VOYAGE_API_KEY   (default model voyage-3-lite)
# ollama = local, requires OLLAMA_URL (default model nomic-embed-text)
EMBEDDINGS_PROVIDER=none
EMBEDDINGS_MODEL=
OPENAI_API_KEY=
# Optional OpenAI-compatible API base URL (useful for gateways or local mocks).
OPENAI_BASE_URL=
VOYAGE_API_KEY=
OLLAMA_URL=
