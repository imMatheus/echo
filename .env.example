# Copy to .env for Docker Compose, or export in your shell for local dev.

# --- Database -----------------------------------------------------------
# Docker Compose uses the matching `echo` defaults below. If you change the raw
# Postgres password, also set ECHO_DATABASE_URL with its
# password component percent-encoded so URL-reserved characters are safe.
# For local dev (docker-compose.dev.yml) the default is:
#   postgres://echo:echo@localhost:5433/echo
POSTGRES_PASSWORD=echo
# Required companion override for POSTGRES_PASSWORD=p@ss/word:
# ECHO_DATABASE_URL=postgres://echo:p%40ss%2Fword@db:5432/echo
ECHO_DATABASE_URL=
# Used by the server when it runs directly on the host. Compose deliberately
# ignores this value so a host-only URL cannot override its internal db service.
DATABASE_URL=postgres://echo:echo@localhost:5433/echo
DEV_DB_PORT=5433

# --- Server -------------------------------------------------------------
# Public URL of this deployment (enables Secure cookies when https).
APP_URL=
# Set true to run behind a reverse proxy (respect X-Forwarded-* headers).
TRUST_PROXY=false
# Set true after provisioning trusted accounts. This version does not verify
# email ownership, so public signup is unsafe for shared/org deployments.
DISABLE_SIGNUP=false
SESSION_TTL_DAYS=30
# Docker Compose host interface. Keep loopback until trusted accounts are provisioned
# and public signup is disabled.
BIND_ADDRESS=127.0.0.1
PORT=3246
LOG_LEVEL=info

# --- Semantic search ----------------------------------------------------
# pgvector stores the vectors; a provider must generate them.
# none   = keyword (full-text) search only, zero external dependencies
# openai = requires OPENAI_API_KEY   (default model text-embedding-3-small)
# voyage = requires VOYAGE_API_KEY   (default model voyage-3-lite)
# ollama = local, requires OLLAMA_URL (default model nomic-embed-text)
EMBEDDINGS_PROVIDER=none
EMBEDDINGS_MODEL=
OPENAI_API_KEY=
# Optional OpenAI-compatible API base URL (useful for gateways or local mocks).
OPENAI_BASE_URL=
VOYAGE_API_KEY=
OLLAMA_URL=
